local function escanearSeguridadArmario(personaje)
	if not personaje then return false end
	if personaje:GetAttribute("Hidden") == true or personaje:GetAttribute("IsHidden") == true or personaje:GetAttribute("Hiding") == true then return true end
	local jugador = Players:GetPlayerFromCharacter(personaje)
	if jugador and (jugador:GetAttribute("Hidden") == true or jugador:GetAttribute("IsHidden") == true) then return true end
	local ancestro = personaje.Parent
	while ancestro and ancestro ~= workspace do
		local nL = ancestro.Name:lower()
		if nL:find("closet") or nL:find("wardrobe") or nL:find("bed") or nL:find("hide") or nL:find("armario") then return true end
		ancestro = ancestro.Parent
	end
	if personaje:FindFirstChild("InCloset") or personaje:FindFirstChild("Escondido") or personaje:FindFirstChild("HidingIn") or personaje:FindFirstChild("Hiding") then return true end
	local rootPart = personaje:FindFirstChild("HumanoidRootPart")
	local upperTorso = personaje:FindFirstChild("UpperTorso") or personaje:FindFirstChild("Torso")
	if upperTorso and rootPart and upperTorso.Transparency >= 0.9 and rootPart.Transparency >= 0.9 then return true end
	if rootPart then
		for _, sala in ipairs(currentRooms:GetChildren()) do
			local assets = sala:FindFirstChild("Assets") or sala
			for _, obj in ipairs(assets:GetChildren()) do
				local n = obj.Name:lower()
				if n:find("closet") or n:find("wardrobe") or n:find("bed") then
					local mainPart = obj.PrimaryPart or obj:FindFirstChild("Hitbox") or obj:FindFirstChild("Main")
					if mainPart and mainPart:IsA("BasePart") then
						if (rootPart.Position - mainPart.Position).Magnitude < 4.5 then return true end
					end
				end
			end
		end
	end
	return false
end

