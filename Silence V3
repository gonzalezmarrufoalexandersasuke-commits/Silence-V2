local function generarParticulasGlitchEnSala(sala)
    if not sala or not entidad or not entidad.Parent then return end
    local centroSala = sala:FindFirstChild("RoomStart") or sala:FindFirstChild("Floor") or sala:FindFirstChild("PrimaryPart")
    if not centroSala or not centroSala:IsA("BasePart") then return end
    
    for i = 1, math.random(12, 18) do
        local offsetAleatorio = Vector3.new(math.random(-25, 25), math.random(0, 10), math.random(-25, 25))
        local contenedorParticulas = Instance.new("Part")
        contenedorParticulas.Size = Vector3.new(1, 1, 1)
        contenedorParticulas.Transparency = 1
        contenedorParticulas.Anchored = true
        contenedorParticulas.CanCollide = false
        contenedorParticulas.Position = centroSala.Position + offsetAleatorio
        contenedorParticulas.Parent = workspace
        CollectionService:AddTag(contenedorParticulas, "BasuraEstela")
        
        local emisorCirculos = Instance.new("ParticleEmitter")
        emisorCirculos.Texture = "rbxassetid://6079375253" 
        emisorCirculos.Color = ColorSequence.new(Color3.fromRGB(0, 170, 255))
        emisorCirculos.Size = NumberSequence.new({NumberKeypoint.new(0, 0.4), NumberKeypoint.new(1, 0)})
        emisorCirculos.Rate = 350 
        emisorCirculos.Speed = NumberRange.new(8, 25)
        emisorCirculos.Lifetime = NumberRange.new(0.5, 1.2)
        emisorCirculos.SpreadAngle = Vector2.new(360, 360)
        emisorCirculos.Parent = contenedorParticulas
        
        local emisorCuadrados = Instance.new("ParticleEmitter")
        emisorCuadrados.Texture = "rbxassetid://258129505" 
        emisorCuadrados.Color = ColorSequence.new(Color3.fromRGB(0, 85, 255))
        emisorCuadrados.Size = NumberSequence.new({NumberKeypoint.new(0, 0.5), NumberKeypoint.new(1, 0)})
        emisorCuadrados.Rate = 350 
        emisorCuadrados.Speed = NumberRange.new(8, 28)
        emisorCuadrados.Lifetime = NumberRange.new(0.4, 1.1)
        emisorCuadrados.SpreadAngle = Vector2.new(360, 360)
        emisorCuadrados.Parent = contenedorParticulas
        
        task.delay(0.35, function()
            if emisorCirculos then emisorCirculos.Enabled = false end
            if emisorCuadrados then emisorCuadrados.Enabled = false end
            task.wait(1.5)
            if contenedorParticulas then contenedorParticulas:Destroy() end
        end)
    end
end

_G.B35_Shared.SoltarParticulas = generarParticulasGlitchEnSala

