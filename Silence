local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local jugadorLocal = Players.LocalPlayer
local personaje = jugadorLocal.Character or jugadorLocal.CharacterAdded:Wait()
local torso = personaje:WaitForChild("HumanoidRootPart")
local humanoide = personaje:WaitForChild("Humanoid")

-- 1. Iluminación morada y techo negro
Lighting.Ambient = Color3.fromRGB(150, 20, 200)
Lighting.OutdoorAmbient = Color3.fromRGB(100, 0, 150)
Lighting.ColorShift_Top = Color3.fromRGB(0, 0, 0)

-- 2. Audio de fondo en Loop
local sonidoFondo = Instance.new("Sound")
sonidoFondo.SoundId = "rbxassetid://1868779360"
sonidoFondo.Volume = 1
sonidoFondo.Looped = true
sonidoFondo.Parent = workspace
sonidoFondo:Play()

-- 3. Mover objetos del mapa
local palabrasClave = {
	"clock", "reloj", "watch", "plant", "pot", "plantpot", "bush", "flower", "tree", "planta", "maceta",
	"suitcase", "luggage", "bag", "baggage", "briefcase", "maleta", "equipaje", "cart", "trolley", "carriage", "carrito",
	"board", "plank", "tabla", "book", "bookshelf", "shelf", "librero", "estante", "table", "desk", "bench", "mesa",
	"escritorio", "wardrobe", "closet", "cabinet", "drawer", "armario", "cajonera", "bed", "cama"
}

local function esReloj(nombre)
	local n = string.lower(nombre)
	return string.find(n, "clock") or string.find(n, "reloj") or string.find(n, "watch")
end

local function esObjetoGeneral(nombre)
	local nombreL = string.lower(nombre)
	for _, palabra in ipairs(palabrasClave) do
		if string.find(nombreL, palabra) then return true end
	end
	return false
end

for _, objeto in ipairs(workspace:GetDescendants()) do
	if esReloj(objeto.Name) then
		local posicionFrente = torso.CFrame * CFrame.new(0, 1, -4)
		if objeto:IsA("Model") then
			objeto:PivotTo(posicionFrente)
		elseif objeto:IsA("BasePart") and not objeto:FindFirstAncestorOfClass("Model") then
			objeto.CFrame = posicionFrente
		end
	elseif esObjetoGeneral(objeto.Name) then
		local movimiento = CFrame.new(math.random(-4, 4), math.random(2, 5), math.random(-4, 4)) 
			* CFrame.Angles(math.rad(math.random(-20, 20)), math.rad(math.random(0, 360)), math.rad(math.random(-20, 20)))

		if objeto:IsA("Model") then
			objeto:PivotTo(objeto:GetPivot() * movimiento)
		elseif objeto:IsA("BasePart") and not objeto:FindFirstAncestorOfClass("Model") then
			objeto.CFrame = movimiento
		end
	end
end

-- 4. Creación y Movimiento de la Entidad
task.spawn(function()
	task.wait(4.5)

	-- Buscar la Puerta 1 o Habitación inicial
	local puntoSpawneo = workspace:FindFirstChild("0") or workspace:FindFirstChild("1") or workspace:FindFirstChild("Room1") or workspace:FindFirstChild("Door1")
	local posicionInicial = torso.CFrame * CFrame.new(0, 0, -30)

	if puntoSpawneo then
		if puntoSpawneo:IsA("Model") then
			posicionInicial = puntoSpawneo:GetPivot()
		elseif puntoSpawneo:IsA("BasePart") then
			posicionInicial = puntoSpawneo.CFrame
		end
	end

	-- Sonido
	local sonidoEntidad = Instance.new("Sound")
	sonidoEntidad.SoundId = "rbxassetid://135376180128296"
	sonidoEntidad.Volume = 2
	sonidoEntidad.Looped = true
	sonidoEntidad.Parent = workspace
	sonidoEntidad:Play()

	-- Bloque Base Invisible
	local entidad = Instance.new("Part")
	entidad.Name = "EntidadCustom"
	entidad.Size = Vector3.new(8, 8, 0.2)
	entidad.Transparency = 1
	entidad.CanCollide = false
	entidad.Anchored = true
	entidad.CFrame = posicionInicial
	entidad.Parent = workspace

	-- Función auxiliar para crear la imagen en cada cara
	local function crearImagenGui(cara)
		local sg = Instance.new("SurfaceGui")
		sg.Face = cara
		sg.LightInfluence = 0 -- Se ve perfectamente en la oscuridad
		sg.AlwaysOnTop = false
		sg.Parent = entidad

		local img = Instance.new("ImageLabel")
		img.Size = UDim2.new(1, 0, 1, 0)
		img.BackgroundTransparency = 1
		img.Image = "rbxassetid://11498777949"
		img.Parent = sg
	end

	crearImagenGui(Enum.NormalId.Front)
	crearImagenGui(Enum.NormalId.Back)

	task.wait(2)

	-- Recorrido seguro por las habitaciones (siguiendo las partes del mapa)
	local habitaciones = workspace:GetChildren()
	for _, habitacion in ipairs(habitaciones) do
		local estaEscondido = personaje:FindFirstChild("Hidden") or personaje:FindFirstChild("Escondido") or personaje:FindFirstChild("Hiding")
		if estaEscondido then
			entidad:Destroy()
			sonidoEntidad:Stop()
			break
		end

		-- Verificar distancia para matar al jugador
		if (entidad.Position - torso.Position).Magnitude < 6 and not estaEscondido then
			humanoide.Health = 0
			break
		end

		-- Mover la entidad hacia la parte principal de la habitación para no atravesar paredes
		if habitacion:IsA("Model") or habitacion:IsA("BasePart") then
			local destino = habitacion:IsA("Model") and (habitacion.PrimaryPart and habitacion.PrimaryPart.Position or habitacion:GetPivot().Position) or habitacion.Position
			
			-- Alineamos la rotación hacia donde se mueve
			local nuevaCFrame = CFrame.new(destino, torso.Position)
			local tiempoMover = (entidad.Position - destino).Magnitude / 40

			local tween = TweenService:Create(entidad, TweenInfo.new(tiempoMover, Enum.EasingStyle.Linear), {CFrame = nuevaCFrame})
			tween:Play()
			tween.Completed:Wait()
		end
	end
end)

